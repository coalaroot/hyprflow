{
  "layer": "top",
  "position": "top",
  "modules-left": ["clock", "custom/weather"],
  "modules-center": ["hyprland/workspaces", "mpd", "custom/cava"],
  "modules-right": [
    "tray",
    "bluetooth",
    "pulseaudio",
    "custom/battery",
    "custom/swaync",
    "custom/power"
  ],

  "clock": {
    "format": "{:%H:%M ŌÄ» %A ŌÄ» %d.%m}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "on-click": "hyprctl dispatch exec '[float;size 1200 1000;center] gnome-calendar'"
  },

  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": "json",
    "interval": 1800,
    "signal": 1,
    "tooltip": true,
    "restart-interval": 10,
    "on-click": "pkill -SIGRTMIN+1 waybar; hyprctl dispatch exec '[float;size 1200 1200;center] kitty --hold curl wttr.in'"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "persistent-workspaces": {
      "Virtual-1": [1, 2, 3, 4, 5]
    }
  },

  "mpd": {
    "server": "127.0.0.1",
    "port": 6600,
    "format": "{filename}",
    "format-paused": "{filename}",
    "format-stopped": "",
    "format-disconnected": "",
    "max-length": 35,
    "on-click-right": "mpc toggle",
    "on-click": "hyprctl dispatch exec '[float;size 1000 750;center] kitty --class ncmpcpp ncmpcpp'",
    "on-scroll-up": "mpc prev",
    "on-scroll-down": "mpc next",
    "tooltip": false
  },

  "custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "mpc toggle"
  },

  "tray": {
    "spacing": 12
  },

  "bluetooth": {
    "format": "",
    "format-connected": " {device_alias}",
    "format-connected-battery": " {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias} ({controller_address})",
    "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} ({device_address})",
    "on-click": "hyprctl dispatch exec '[float;size 1200 600;center] kitty --class bluetui bluetui'"
  },

  "pulseaudio": {
    "format": "’Ć© {volume}%",
    "format-muted": "¾░Ø¤ muted",
    "on-click": "hyprctl dispatch exec '[float;size 1200 800;center] kitty pulsemixer'"
  },

  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "return-type": "json",
    "interval": 30,
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/battery-toggle.sh"
  },

  "custom/swaync": {
    "format": "{icon}{0}",
    "format-icons": {
      "none": "’ā│",
      "notification": "’ā│ ",
      "dnd-none": "’ćČ",
      "dnd-notification": "’ćČ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb | stdbuf -oL sed 's/\"text\": \"0\"/\"text\": \"\"/'",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
    "tooltip": false
  },

  "custom/power": {
    "format": "’Ćæ",
    "on-click": "wlogout",
    "tooltip": false
  },

  "network": {
    "format-wifi": "’ć½  {essid}",
    "format-ethernet": "’āü wired",
    "format-disconnected": "’ä¦",
    "max-length": 20,
    "on-click": "nm-connection-editor"
  }
}
